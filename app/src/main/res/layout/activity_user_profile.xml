<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wk_app_shell_bg"
    android:orientation="vertical">

    <include layout="@layout/action_bar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/user_phone_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account and plan"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:textColor="@color/wk_overlay_dark_text"
                android:textStyle="bold" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/subscription_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/wk_app_card_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/subscription_package"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Package Name"
                        android:textColor="@color/wk_overlay_dark_text"
                        android:textSize="18dp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/purchase_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Purchase Icon"
                        android:src="@drawable/network_intelligence_24px"
                        app:tint="@color/wk_overlay_dark_accent" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginVertical="8dp"
                    >

                    <TextView
                        android:id="@+id/subscription_status_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Status:"
                        android:textAppearance="?android:attr/textAppearanceMedium"
                        android:textColor="@color/wk_overlay_dark_text2"
                        android:textSize="14dp" />

                    <TextView
                        android:id="@+id/subscription_status_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=" $YY"
                        android:textAlignment="textEnd"
                        android:textColor="@color/wk_overlay_dark_text2"
                        android:textSize="16dp"
                        android:textStyle="bold"
                        />

                </LinearLayout>


                <com.google.android.material.button.MaterialButton
                    android:id="@+id/renew_button"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_gravity="end"
                    android:backgroundTint="@color/wk_overlay_dark_accent"
                    android:text="View plans"
                    android:textColor="@color/primary_app_color"
                    android:textSize="16dp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/renewal_icon"
                    app:iconTint="@color/primary_app_color" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >
            <TextView
                android:id="@+id/cancel_subscription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel Subscription"
                android:textColor="@color/wk_overlay_dark_text2"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/delete_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Request account deletion"
                android:textColor="@color/wk_overlay_dark_text2"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingVertical="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/logout_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"
                android:paddingHorizontal="10dp"
                android:backgroundTint="@color/wk_overlay_dark_accent"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:textColor="@color/primary_app_color"
                android:textFontWeight="700"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.WittyKeys.Button.Circle" />

        </LinearLayout>
    </LinearLayout>
</LinearLayout>
