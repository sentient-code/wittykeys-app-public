<?xml version="1.0" encoding="utf-8"?>
<!-- Task 2.27: Milestone toast layout - green pill overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/milestone_toast_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:visibility="gone">

    <!-- Toast Pill -->
    <LinearLayout
        android:id="@+id/milestone_toast_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/wk_milestone_toast_bg"
        android:elevation="4dp">

        <!-- Confetti/Celebration Emoji -->
        <TextView
            android:id="@+id/milestone_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="🎉"
            tools:ignore="HardcodedText" />

        <!-- Single-line message: title + subtitle -->
        <TextView
            android:id="@+id/milestone_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="10 replies sent! You saved 847 keystrokes" />

        <!-- Hidden subtitle (title now contains full message) -->
        <TextView
            android:id="@+id/milestone_subtitle"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Close Button -->
        <TextView
            android:id="@+id/milestone_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:alpha="0.7"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/close" />

    </LinearLayout>

</FrameLayout>
