<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/wk_app_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/card_header_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your WittyKeys setup"
        android:textColor="@color/wk_overlay_dark_text"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/card_header_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Use the tools you enabled. Finish the rest anytime."
        android:textColor="@color/wk_overlay_dark_text2"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/item_layout_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/item_icon_1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Keyboard enabled status"
            android:src="@drawable/ic_check_box_blank"
            app:tint="@color/wk_overlay_dark_text2" />

        <TextView
            android:id="@+id/item_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Keyboard enabled"
            android:textColor="@color/wk_overlay_dark_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_layout_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/item_icon_2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Default keyboard status"
            android:src="@drawable/ic_check_box_blank"
            app:tint="@color/wk_overlay_dark_text2" />

        <TextView
            android:id="@+id/item_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Default keyboard selected"
            android:textColor="@color/wk_overlay_dark_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_layout_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/wk_app_card_quiet_bg"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/item_icon_3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="3dp"
            android:contentDescription="AI credits status"
            android:src="@drawable/ic_brain"
            app:tint="@color/wk_overlay_dark_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="20 free AI credits/day"
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/item_subtitle_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Try Reply, Scan, Tone, Grammar, Translate, and AI Chat daily."
                android:textColor="@color/wk_overlay_dark_text2"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/item_progress_layout_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ProgressBar
                    android:id="@+id/item_progress_bar_3"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="20"
                    android:progress="0"
                    android:progressTint="@color/wk_overlay_dark_accent"
                    tools:progress="14" />

                <TextView
                    android:id="@+id/item_progress_text_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="5dp"
                    android:text="20 free AI credits/day"
                    android:textColor="@color/wk_overlay_dark_text2"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_button_3"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/wk_overlay_dark_accent"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Use free daily access"
                android:textAllCaps="false"
                android:textColor="@color/primary_app_color"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="15dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_layout_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/wk_app_card_quiet_bg"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/item_icon_4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginTop="3dp"
            android:contentDescription="Upgrade status"
            android:src="@drawable/ic_check_circle_24"
            app:tint="@color/wk_overlay_dark_accent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_title_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upgrade for more AI credits"
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/item_subtitle_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Increase your AI credit allowance when daily use grows."
                android:textColor="@color/wk_overlay_dark_text2"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_button_4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Upgrade"
                android:textAllCaps="false"
                android:textColor="@color/wk_overlay_dark_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                app:cornerRadius="15dp"
                app:strokeColor="@color/wk_overlay_dark_accent"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/item_layout_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:id="@+id/item_icon_5"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="Ready status"
            android:src="@drawable/ic_check_box_blank"
            app:tint="@color/wk_overlay_dark_text2" />

        <TextView
            android:id="@+id/item_title_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Enjoy WittyKeys"
            android:textColor="@color/wk_overlay_dark_text"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
