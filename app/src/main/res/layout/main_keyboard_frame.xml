<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical">
    <!-- Replace MainKeyboardView-->
    <project.witty.keys.keyboard.EmojiKeyboard.EmojiKeyboard
        android:id="@+id/emoji_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />


    <project.witty.keys.keyboard.ProductViews.UnifiedAiView
        android:id="@+id/unified_ai_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>


    <project.witty.keys.keyboard.AssistantViews.AiViewAssistant
        android:id="@+id/ai_view_assistant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        />

    <!-- LAYER 2: The Standard Keyboard Block -->
    <!-- This new LinearLayout is the key. It groups the keyboard and its helper rows. -->
    <!-- Animating this single view will animate all its children in perfect sync. -->
    <LinearLayout
        android:id="@+id/keyboard_block_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible"> <!-- Start with the keyboard visible -->
        <!-- SmartAssistantBar - Unified assistant UI (Build 6.3) -->
        <!-- Replaces UtilityRow + SuggestionRow with single component -->
        <project.witty.keys.keyboard.AssistantViews.SmartAssistantBar
            android:id="@+id/smart_assistant_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />


        <!-- The FrameLayout for the keyboard is no longer needed here, -->
        <!-- as MainKeyboardView can be a direct child of the LinearLayout. -->
        <project.witty.keys.keyboard.MainKeyboardView
            android:id="@+id/keyboard_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layoutDirection="ltr" />

    </LinearLayout>
    <!-- End of the Keyboard Block Layer -->


</LinearLayout>
