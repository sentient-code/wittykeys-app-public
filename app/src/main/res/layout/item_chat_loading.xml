<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="48dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- AI Avatar -->
    <TextView
        android:id="@+id/ai_avatar_loading"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="6dp"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textSize="16sp"
        android:background="@drawable/bg_ai_avatar"
        android:text="\uD83E\uDD16" />

    <!-- Typing dots bubble — clipChildren false so bounce animation isn't cropped -->
    <LinearLayout
        android:id="@+id/typing_dots_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@drawable/bg_bubble_ai">

        <View
            android:id="@+id/dot1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/dot2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_typing_dot" />

        <View
            android:id="@+id/dot3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_typing_dot" />
    </LinearLayout>
</LinearLayout>
