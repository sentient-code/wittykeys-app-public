<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/wk_ds_strip_mini_header_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <View
            android:id="@+id/wkStripDot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_wk_source_tag_kbd"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/wkStripQuoteBar"
            android:layout_width="2dp"
            android:layout_height="20dp"
            android:layout_marginEnd="6dp"
            android:background="@color/wk_purple"
            android:visibility="gone" />

        <TextView
            android:id="@+id/wkStripTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/wkText" />

        <TextView
            android:id="@+id/wkStripQuote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="11sp"
            android:textColor="@color/wk_text_sec"
            android:ellipsize="end"
            android:maxLines="1"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/wkStripSessions"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="5dp"
            android:src="@drawable/ic_wk_sessions"
            android:background="@drawable/bg_wk_icon_btn"
            android:contentDescription="@string/wk_ds_sessions_cd"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp" />

        <ImageView
            android:id="@+id/wkStripClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:padding="5dp"
            android:src="@drawable/ic_wk_close"
            android:background="@drawable/bg_wk_icon_btn"
            android:contentDescription="@string/wk_ds_close_cd"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</merge>
