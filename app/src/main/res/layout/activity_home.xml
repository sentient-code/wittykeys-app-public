<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wk_app_shell_bg">

    <ScrollView
        android:id="@+id/home_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="106dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="24dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/home_top_identity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/wk_logo_rounded_square_bg"
                    android:clipToOutline="true"
                    android:contentDescription="WittyKeys logo"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_witty_logo" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WittyKeys"
                        android:textColor="@color/wk_overlay_dark_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/home_top_subtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Anonymous mode"
                        android:textColor="@color/wk_overlay_dark_text2"
                        android:textSize="14sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/home_action_menu"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/wk_app_card_quiet_bg"
                    android:contentDescription="Open settings"
                    android:padding="14dp"
                    android:src="@drawable/settings_icon"
                    app:tint="@color/wk_overlay_dark_text" />

                <ImageButton
                    android:id="@+id/home_profile_button"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/wk_app_card_quiet_bg"
                    android:contentDescription="Open account"
                    android:padding="14dp"
                    android:src="@drawable/user_icon"
                    app:tint="@color/wk_overlay_dark_text" />
            </LinearLayout>

            <TextView
                android:id="@+id/home_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="Use AI without signing in."
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Use AI without signing in." />

            <TextView
                android:id="@+id/home_subhead"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Start with free daily actions. Sign in only for Plus and account management."
                android:textColor="@color/wk_overlay_dark_text2"
                android:textSize="16sp"
                tools:text="Start with free daily actions. Sign in only for Plus and account management." />

            <LinearLayout
                android:id="@+id/home_product_stage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/wk_app_card_hero_bg"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/home_state_mark"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="@color/primary_app_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/home_stage_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Free plan ready"
                            android:textColor="@color/wk_overlay_dark_text"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            tools:text="Free plan ready" />

                        <TextView
                            android:id="@+id/home_stage_subtitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Overlay, Quick Reply, and Keyboard are available."
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="13sp"
                            tools:text="Overlay, Quick Reply, and Keyboard are available." />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/home_credit_value"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="10dp"
                        android:gravity="center"
                        android:paddingHorizontal="13dp"
                        android:text="18 left"
                        android:textColor="@color/primary_app_color"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="18 left" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/home_primary_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/home_feature_overlay"
                        android:layout_width="0dp"
                        android:layout_height="152dp"
                        android:layout_weight="1"
                        android:background="@drawable/wk_app_card_hero_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="OVERLAY"
                            android:textColor="@color/wk_overlay_dark_accent"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Ask AI about screens"
                            android:textColor="@color/wk_overlay_dark_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="6dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="AI from any app."
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="11sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/home_primary_button"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:backgroundTint="@color/wk_overlay_dark_accent"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:layout_marginTop="8dp"
                            android:paddingHorizontal="14dp"
                            android:text="Open Overlay"
                            android:textAllCaps="false"
                            android:textColor="@color/primary_app_color"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:cornerRadius="17dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/home_feature_keyboard"
                        android:layout_width="0dp"
                        android:layout_height="152dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/wk_app_card_quiet_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="KEYBOARD"
                            android:textColor="@color/wk_overlay_dark_accent"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Write better anywhere"
                            android:textColor="@color/wk_overlay_dark_text"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_marginTop="6dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="Rewrite, tone, chat."
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/home_keyboard_button"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/wk_app_card_quiet_bg"
                            android:gravity="center"
                            android:paddingHorizontal="14dp"
                            android:text="Keyboard tools"
                            android:textColor="@color/wk_overlay_dark_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/home_credit_strip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:background="@drawable/wk_app_card_quiet_bg"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/home_credit_caption"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="20 AI actions/day"
                            android:textColor="@color/wk_overlay_dark_text"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="20 AI actions/day" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/home_upgrade_button"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="34dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingHorizontal="12dp"
                            android:text="Upgrade"
                            android:textAllCaps="false"
                            android:textColor="@color/wk_overlay_dark_accent"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/home_credit_meter"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginTop="10dp"
                        android:max="20"
                        android:progress="18"
                        android:progressTint="@color/wk_overlay_dark_accent"
                        tools:progress="18" />

                    <LinearLayout
                        android:id="@+id/home_setup_checks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:id="@+id/home_setup_check_1"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:background="@drawable/wk_app_card_bg"
                            android:gravity="center"
                            android:text="ON\nOverlay"
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/home_setup_check_2"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/wk_app_card_bg"
                            android:gravity="center"
                            android:text="ON\nQuick Reply"
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/home_setup_check_3"
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/wk_app_card_bg"
                            android:gravity="center"
                            android:text="ON\nKeyboard"
                            android:textColor="@color/wk_overlay_dark_text2"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/home_stage_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/wk_overlay_dark_text2"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="exhausted daily limit will reset soon"
                        tools:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/home_action_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/enable_instruction_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/home_bottom_nav"
        style="@style/WkAppBottomNav"
        android:layout_gravity="bottom">

        <TextView
            android:id="@+id/home_nav_home"
            style="@style/WkAppBottomNavItemActive"
            android:text="Home" />

        <TextView
            android:id="@+id/home_nav_usage"
            style="@style/WkAppBottomNavItem"
            android:text="Usage" />

        <TextView
            android:id="@+id/home_nav_settings"
            style="@style/WkAppBottomNavItem"
            android:text="Settings" />
    </LinearLayout>

    <nl.dionsegijn.konfetti.xml.KonfettiView
        android:id="@+id/konfettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</FrameLayout>
