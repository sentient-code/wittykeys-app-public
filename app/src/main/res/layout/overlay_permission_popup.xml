<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/wk_permission_modal_bg"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/wk_permission_logo_halo_bg">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:contentDescription="WittyKeys"
                android:src="@drawable/wk_logo_overlay" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/overlay_perm_step_label"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:background="@drawable/wk_permission_step_pill_bg"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Step 1 of 2"
                android:textColor="@color/wk_overlay_dark_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_perm_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:includeFontPadding="false"
                android:text="Enable Floating Assistant"
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/overlay_perm_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:lineSpacingExtra="3dp"
        android:text="WittyKeys explains every permission before Android asks."
        android:textColor="@color/wk_overlay_dark_text2"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/overlay_perm_steps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/overlay_perm_detail_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/wk_permission_detail_bg"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/wk_permission_detail_dot_bg"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/wk_overlay_dark_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_perm_detail_1_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Shows the WittyKeys bubble above apps."
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlay_perm_detail_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/wk_permission_detail_bg"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/wk_permission_detail_dot_bg"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/wk_overlay_dark_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_perm_detail_2_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Lets you open AI Chat without switching apps."
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/overlay_perm_detail_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/wk_permission_detail_bg"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/wk_permission_detail_dot_bg"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/wk_overlay_dark_accent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_perm_detail_3_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="You can disable this anytime in Settings."
                android:textColor="@color/wk_overlay_dark_text"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/overlay_perm_grant_btn"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/wk_button_gradient"
        android:backgroundTint="@null"
        android:contentDescription="Grant permissions"
        android:text="Grant Access"
        android:textAllCaps="false"
        android:textColor="@color/wk_overlay_dark_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/overlay_perm_skip"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="4dp"
        android:clickable="true"
        android:contentDescription="Skip permission setup"
        android:focusable="true"
        android:gravity="center"
        android:text="Skip for now"
        android:textColor="@color/wk_overlay_dark_text2"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
