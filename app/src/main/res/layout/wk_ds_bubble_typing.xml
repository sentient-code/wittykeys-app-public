<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_wk_msg_ai"
        android:paddingStart="@dimen/wk_ds_bubble_padding_h"
        android:paddingEnd="@dimen/wk_ds_bubble_padding_h"
        android:paddingTop="@dimen/wk_ds_bubble_padding_v"
        android:paddingBottom="@dimen/wk_ds_bubble_padding_v">

        <View
            android:id="@+id/wkTypingDot1"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_typing_dot"
            android:layout_marginEnd="4dp" />
        <View
            android:id="@+id/wkTypingDot2"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_typing_dot"
            android:layout_marginEnd="4dp" />
        <View
            android:id="@+id/wkTypingDot3"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_typing_dot" />
    </LinearLayout>
</merge>
