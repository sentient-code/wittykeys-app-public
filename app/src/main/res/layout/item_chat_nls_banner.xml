<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/nls_banner_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/wk_nls_banner_bg">

    <!-- Header: 📲 Recent messages from {contact} -->
    <TextView
        android:id="@+id/nls_banner_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📲 Recent messages"
        android:textSize="13sp"
        android:textColor="#E5A78BFA"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <!-- Message list container (dynamically populated) -->
    <LinearLayout
        android:id="@+id/nls_messages_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />
</LinearLayout>
