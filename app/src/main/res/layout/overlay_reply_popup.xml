<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_popup_bg"
    android:maxHeight="460dp">

    <!-- Header: app icon + contact name + Open link -->
    <LinearLayout
        android:id="@+id/overlay_reply_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <!-- App icon container with colored bg -->
        <FrameLayout
            android:id="@+id/overlay_reply_icon_frame"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/overlay_header_icon_bg">

            <ImageView
                android:id="@+id/overlay_reply_app_icon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="App icon" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/overlay_reply_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/wk_overlay_dark_text"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/overlay_reply_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/wk_overlay_dark_text2"
                android:layout_marginTop="1dp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlay_reply_open_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↗ Open"
            android:textSize="10sp"
            android:textColor="@color/wk_overlay_dark_accent"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/overlay_header_action_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:contentDescription="Open chat app" />
    </LinearLayout>

    <!-- Header border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/wk_overlay_header_border" />

    <!-- Tabs: horizontal scroll of contact tabs (bottom-border style) -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/wk_overlay_dark_surface">

        <LinearLayout
            android:id="@+id/overlay_reply_tabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Tab bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/wk_overlay_tab_divider" />

    <!-- Messages area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/overlay_reply_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:clipToPadding="false" />

    <!-- AI suggestion chips area -->
    <LinearLayout
        android:id="@+id/overlay_reply_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp" />

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="10dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="8dp"
        android:background="@drawable/overlay_reply_input_bar_bg">

        <EditText
            android:id="@+id/overlay_reply_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Type a reply..."
            android:textSize="12sp"
            android:textColor="@color/wk_overlay_dark_text"
            android:textColorHint="@color/wk_overlay_dark_text3"
            android:background="@drawable/overlay_input_bg"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:inputType="text" />

        <ImageButton
            android:id="@+id/overlay_reply_send"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/overlay_send_bg"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Send reply"
            android:tint="#FFFFFF"
            android:scaleType="centerInside"
            android:padding="7dp" />
    </LinearLayout>

</LinearLayout>
