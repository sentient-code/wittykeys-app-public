<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0F">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/onboarding_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="WittyKeys Demo"
            android:textColor="#F0F0F2"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/onboarding_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1/3"
            android:textColor="#8A8A96"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Contact Name -->
    <TextView
        android:id="@+id/onboarding_contact_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:textColor="#8A8A96"
        android:textSize="13sp"
        android:text=""
        app:layout_constraintTop_toBottomOf="@id/onboarding_top_bar" />

    <!-- Chat Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/onboarding_chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/onboarding_contact_name"
        app:layout_constraintBottom_toTopOf="@id/onboarding_chips_scroll" />

    <!-- Reply Chips (horizontally scrollable) -->
    <HorizontalScrollView
        android:id="@+id/onboarding_chips_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="56dp"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toTopOf="@id/onboarding_skip_button">

        <LinearLayout
            android:id="@+id/onboarding_chips_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Skip Button -->
    <TextView
        android:id="@+id/onboarding_skip_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skip \u2192"
        android:textColor="#8A8A96"
        android:textSize="14sp"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
