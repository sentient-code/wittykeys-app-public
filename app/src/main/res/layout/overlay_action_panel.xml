<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_popup_bg"
    android:elevation="12dp"
    android:padding="4dp">

    <!-- Screenshot AI button -->
    <LinearLayout
        android:id="@+id/overlay_btn_screenshot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/overlay_action_btn_bg"
        android:padding="11dp"
        android:layout_margin="4dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="AI Chat">

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/overlay_action_icon_bg_screenshot">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📸"
                android:textSize="16sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Chat"
                android:textSize="12sp"
                android:textColor="@color/wk_overlay_dark_text"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat &amp; capture"
                android:textSize="9sp"
                android:textColor="@color/wk_overlay_dark_text3"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Quick Replies button -->
    <LinearLayout
        android:id="@+id/overlay_btn_replies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/overlay_action_btn_bg"
        android:padding="11dp"
        android:layout_margin="4dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Quick Replies">

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/overlay_action_icon_bg_replies">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="💬"
                android:textSize="16sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Replies"
                android:textSize="12sp"
                android:textColor="@color/wk_overlay_dark_text"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI suggestions"
                android:textSize="9sp"
                android:textColor="@color/wk_overlay_dark_text3"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Badge count -->
        <TextView
            android:id="@+id/overlay_action_reply_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="18dp"
            android:background="@drawable/overlay_action_badge_bg"
            android:gravity="center"
            android:paddingHorizontal="7dp"
            android:paddingVertical="2dp"
            android:textColor="#000000"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
