<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_popup_bg"
    android:maxHeight="480dp">

    <!-- Header: icon + title/subtitle + Expand -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp">

        <!-- Header icon -->
        <FrameLayout
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@drawable/overlay_header_icon_bg">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="📸"
                android:textSize="14sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/overlay_screenshot_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Chat"
                android:textSize="13sp"
                android:textColor="@color/wk_overlay_dark_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_screenshot_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analyzing..."
                android:textSize="10sp"
                android:textColor="@color/wk_overlay_dark_text2"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/overlay_screenshot_expand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↗ Expand"
            android:textSize="10sp"
            android:textColor="@color/wk_overlay_dark_accent"
            android:textStyle="bold"
            android:background="@drawable/overlay_header_action_bg"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Expand to full screen" />
    </LinearLayout>

    <!-- Content area: history list OR chat messages -->
    <FrameLayout
        android:id="@+id/overlay_screenshot_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <project.witty.keys.ui.chat.WkInputBar
        android:id="@+id/overlay_input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
