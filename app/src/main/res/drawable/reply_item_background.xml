<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for quick reply items in MemoryView
    NOTE: Uses theme attributes for dynamic theming
    Background is applied programmatically in MemoryView.createReplyItem()
    This is a placeholder/fallback that will be replaced at runtime
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state - uses theme attribute -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/themedButtonPressedBackgroundColor"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- Default state - uses theme attributes -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/themedButtonBackgroundColor"/>
            <corners android:radius="8dp"/>
            <stroke
                android:width="1dp"
                android:color="?attr/utilityRowSeparatorColor"/>
        </shape>
    </item>
</selector>
