<?xml version="1.0" encoding="utf-8"?>
<!-- Custom mode chip with dashed border - matching mockup -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="@dimen/wk_chip_border_width"
        android:color="@color/wk_custom_purple_border"
        android:dashWidth="4dp"
        android:dashGap="2dp" />
    <corners android:radius="@dimen/wk_chip_radius" />
</shape>
