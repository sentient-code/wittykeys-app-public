<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="@color/wk_bs_gradient_top"
                android:endColor="@color/wk_bs_gradient_bottom"
                android:angle="270"/>
            <corners android:topLeftRadius="@dimen/wk_bs_sheet_radius"
                android:topRightRadius="@dimen/wk_bs_sheet_radius"/>
            <stroke android:width="1dp" android:color="@color/wk_bs_border"/>
        </shape>
    </item>
</layer-list>
