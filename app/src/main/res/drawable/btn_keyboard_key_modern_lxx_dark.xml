<?xml version="1.0" encoding="utf-8"?>
<!-- State list drawable for modern key backgrounds in dark theme -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state uses pressed background -->
    <item android:state_pressed="true" android:drawable="@drawable/modern_key_shape_pressed_lxx_dark" />
    <!-- Default state uses normal background -->
    <item android:drawable="@drawable/modern_key_shape_lxx_dark" />
</selector>
