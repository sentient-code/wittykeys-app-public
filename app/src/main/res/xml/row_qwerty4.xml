<!-- Round 4 FIX 11: Reordered bottom row to: 123 | emoji | spacebar | , | Enter -->
<merge
    xmlns:latin="http://schemas.android.com/apk/res-auto"
>
    <Row
        latin:keyWidth="10%p">
        <!-- Number pad switch key -->
        <Key
            latin:keyStyle="toSymbolKeyStyle"
            latin:keyWidth="15%p" />
        <!-- Emoji key (moved from position 3 to position 2) -->
        <Key
            latin:keyStyle="toEmojiKeyStyle"
            latin:keyWidth="10%p" />
        <!-- Spacebar -->
        <include
            latin:keyboardLayout="@xml/key_space_5kw" />
        <!-- Comma key (moved from position 2 to between spacebar and enter) -->
        <include
            latin:keyboardLayout="@xml/key_comma"
            latin:keyWidth="10%p" />
        <!-- Enter key matches 123 key width -->
        <Key
            latin:keyStyle="enterKeyStyle"
            latin:keyWidth="15%p" />
    </Row>
</merge>
