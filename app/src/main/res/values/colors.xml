    <!-- Removed themes: Dracula, Solarized, Gruvbox, Monokai, Catppuccin, Everforest, Tokyo Night, Ayu, Rosé Pine -->

    <!-- ==================== MODERN KEY COLORS FOR GBOARD-STYLE THEMES (LXX) ==================== -->
    <!-- Light theme modern pastel key backgrounds -->
    <color name="modern_key_background_lxx_light">#FFFFFF</color>
    <!-- Pressed state for modern keys in light theme -->
    <color name="modern_key_pressed_background_lxx_light">#F5F5F5</color>
    <!-- Functional (shift, backspace) key background for modern light theme -->
    <color name="modern_key_functional_background_lxx_light">#E8E8E8</color>
    <!-- Spacebar key background for modern light theme -->
    <color name="modern_key_spacebar_background_lxx_light">#E8E8E8</color>

    <!-- Dark theme modern key backgrounds (darker to match reference) -->
    <color name="modern_key_background_lxx_dark">#1C1C1E</color>
    <!-- Pressed state for modern keys in dark theme -->
    <color name="modern_key_pressed_background_lxx_dark">#2A2A2C</color>
    <!-- Functional key background for modern dark theme -->
    <color name="modern_key_functional_background_lxx_dark">#1C1C1E</color>
    <!-- Spacebar key background for modern dark theme -->
    <color name="modern_key_spacebar_background_lxx_dark">#1C1C1E</color>

    <!-- Alias for shift/capslock icon tint. This alias points to the functional text color for
         the light theme so that the system-tinted shift icons pick up the appropriate colour.
         If different colours are desired for dark themes, override this definition in
         values-night/colors.xml accordingly. -->
    <color name="key_functional_text_color_lxx_system">@color/key_functional_text_color_lxx_light</color>

    <color name="shimmer_base_light">#E0E0E0</color>     <!-- light grey -->
    <color name="shimmer_highlight_light">#F5F5F5</color>

    <!-- System theme auto-switching colors (light mode defaults, overridden in values-night/) -->
    <color name="background_lxx_system_auto">@color/background_lxx_light</color>
    <color name="key_text_color_lxx_system_auto">@color/key_text_color_lxx_light</color>
    <color name="key_text_inactive_color_lxx_system_auto">@color/key_text_inactive_color_lxx_light</color>
    <color name="key_functional_text_color_lxx_system_auto">@color/key_functional_text_color_lxx_light</color>
    <color name="key_hint_letter_color_lxx_system_auto">@color/key_hint_letter_color_lxx_light</color>

    <!-- Additional auto-switching colors for MainKeyboardView -->
    <color name="sliding_key_input_preview_color_lxx_system_auto">@color/sliding_key_input_preview_color_lxx_light</color>
    <color name="language_on_spacebar_text_color_lxx_system_auto">@color/language_on_spacebar_text_color_lxx_light</color>

