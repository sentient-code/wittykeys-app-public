<!-- Configuration values for Small Phone Portrait. -->
<resources>
    <bool name="config_use_fullscreen_mode">false</bool>

    <dimen name="config_key_hysteresis_distance">5.0dp</dimen>

    <!-- Preferable keyboard height in absolute scale: 1.285in -->
    <!-- This config_default_keyboard_height value should match with keyboard-heights.xml -->
    <!-- Round 6 FIX 16: 138dp makes keys near-square (ratio ~1.0).
         Device: 1080x2640 @ 420dpi → 411.4dp wide. Key cell=10%=41.1dp.
         At H=138dp: keyHeight≈30.6dp, keyWidth≈30.6dp → square keys. -->
    <dimen name="config_default_keyboard_height">131.8dp</dimen>
    <fraction name="config_max_keyboard_height">54%p</fraction>
    <fraction name="config_min_keyboard_height">-61.8%p</fraction>

    <!-- Preferable EmojiBoard height in absolute scale -->
    <dimen name="config_default_emojiBoard_height">300.6dp</dimen>
<!--    <fraction name="config_max_emojiBoard_height">60%p</fraction>-->
<!--    <fraction name="config_min_emojiBoard_height">-61.8%p</fraction>-->

    <!-- Preferable EmojiBoard height in absolute scale -->
    <dimen name="config_default_productView_height">500.6dp</dimen>
<!--    <fraction name="config_max_productView_height">60%p</fraction>-->
<!--    <fraction name="config_min_productView_height">-61.8%p</fraction>-->


    <dimen name="config_more_keys_keyboard_key_height">52.8dp</dimen>
    <!-- Amount of allowance for selecting keys in a mini popup keyboard by sliding finger. -->
    <!-- config_more_keys_keyboard_key_height x 1.2 -->
    <dimen name="config_more_keys_keyboard_slide_allowance">63.36dp</dimen>
    <dimen name="config_more_keys_keyboard_key_horizontal_padding">8dp</dimen>

    <!-- Track 1 Change #12: Reduced outer padding for keys closer to edges -->
    <!-- Round 3 Fix #6: Equalized top and bottom padding so SAB-to-keys gap matches keys-to-bottom gap -->
    <fraction name="config_keyboard_top_padding">0.5%p</fraction>
    <fraction name="config_keyboard_bottom_padding">0.5%p</fraction>
    <fraction name="config_keyboard_left_padding">0.5%p</fraction>
    <fraction name="config_keyboard_right_padding">0.5%p</fraction>
    <!-- Round 5 FIX 15: Recalculated vertical gap for 148dp keyboard height.
         2.66% × 148dp = 3.94dp ≈ horizontal gap (1.0% × 393dp = 3.93dp) — uniform gaps -->
    <fraction name="config_key_vertical_gap">2.66%p</fraction>
    <fraction name="config_key_horizontal_gap">1.0%p</fraction>
    <!-- config_more_keys_keyboard_key_height x -0.5 -->
    <dimen name="config_more_keys_keyboard_vertical_correction">-26.4dp</dimen>
    <dimen name="config_key_preview_offset_lxx">50dp</dimen>
    <dimen name="config_key_preview_height_lxx">122dp</dimen>
    <dimen name="config_key_preview_width_lxx">0dp</dimen>
    <fraction name="config_key_preview_text_ratio">82%</fraction>
    <fraction name="config_key_letter_ratio_lxx">45%</fraction>
    <fraction name="config_key_large_letter_ratio_lxx">90%</fraction>
    <fraction name="config_key_label_ratio_lxx">34%</fraction>
    <fraction name="config_key_hint_letter_ratio_lxx">25%</fraction>
    <fraction name="config_key_hint_label_ratio_lxx">30%</fraction>
    <fraction name="config_key_shifted_letter_hint_ratio_lxx">35%</fraction>
    <fraction name="config_language_on_spacebar_text_ratio">33.735%</fraction>
    <dimen name="config_key_hint_letter_padding">1dp</dimen>
    <dimen name="config_key_shifted_letter_hint_padding">2dp</dimen>

    <dimen name="config_more_keys_keyboard_top_padding">0dp</dimen>
    <dimen name="config_more_keys_keyboard_bottom_padding">0dp</dimen>
    <dimen name="config_more_keys_keyboard_left_padding">0dp</dimen>
    <dimen name="config_more_keys_keyboard_right_padding">0dp</dimen>

    <!-- For 5-row keyboard -->
    <!-- config_key_vertical_gap_5row is calculated to match config_key_horizontal_gap (assuming
         the height is based on config_min_keyboard_height which is true except for very small
         devices) to have a general guideline for a minimum gap between keys. For a 5 row keyboard,
         we shouldn't waste unnecessary space on the gap. -->
    <!-- Round 5 FIX 15: 5-row proportional: 1.72 × (2.66/2.34) ≈ 1.96 -->
    <fraction name="config_key_vertical_gap_5row">1.96%p</fraction>
    <!-- config_key_bonus_height_5row is calculated to be the extra height necessary to keep the 5
         and 4 row keyboards' keys the same height. -->
    <fraction name="config_key_bonus_height_5row">1.194%p</fraction>
    <fraction name="config_key_letter_ratio_5row">55%</fraction>
    <fraction name="config_key_shifted_letter_hint_ratio_5row">41%</fraction>
</resources>
